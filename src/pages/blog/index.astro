---
import {getCollection} from 'astro:content'
// import {Debug} from 'astro:components'
import InfoLayout from "../../layouts/InfoLayout.astro"
import InfoCard from "../../components/InfoCard.astro"
import GoBackTool from "../../components/GoBackTool"

const base = import.meta.env.BASE_URL
const allBlog = await getCollection("blog");

// 辅助函数：获取缩略图路径
function getThumbnailPath(category: string | undefined, thumbnail: string | undefined): string {
    const categoryToThumbnail: Record<string, string> = {
        "微故事": "ACTIVITY.jpg",
        "事件": "NEWS.jpg",
        "世界观": "ANNOUNCEMENT.jpg"
    };
    return thumbnail ?? categoryToThumbnail[category as keyof typeof categoryToThumbnail] ?? "ACTIVITY.jpg";
}
---

<InfoLayout title="Universe" subTitle="宇宙" tabTitle="宇宙">
    <div id="blog-container" class="h-full flex-auto mr-[-16px] overflow-x-hidden overflow-y-scroll">
        <div id="blog-scroll-wrapper">
            <nav id="blog-content" class="max-w-[80.75rem] mx-auto">

                {
                    (allBlog.length > 0) && allBlog.map((item, index) =>
                                <div class="w-full mb-16 flex justify-center blog-item" data-category={item.data.category ?? '未分类'}>
                                    <a target="_blank" href={`${base}blog/${item.slug}`} title={item.data.title ?? item.id} class="w-3/4 block relative">
                                        <img class="w-full h-[250px] object-cover object-center" 
                                             src={`${base}info-thumbnail/${getThumbnailPath(item.data.category, item.data.thumbnail)}`} 
                                             alt="Thumbnail"/>
                                        <div class="absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black/80 to-transparent">
                                            <div class="text-ark-blue text-2xl font-bold mb-2">{item.data.category ?? "未分类"}</div>
                                            <div class="text-white text-4xl font-bold mb-2">{item.data.title ?? item.id}</div>
                                            <div class="text-white/80 text-lg">{item.id.substring(0, 4)} // {item.id.substring(5, 7)} / {item.id.substring(8, 10)}</div>
                                        </div>
                                    </a>
                                </div>
                            )
                }
                <!--<Debug {allBlog}/>-->
            </nav>
            <div class="text-center text-2xl font-n15eBold pt-12 pb-16">- END -</div>
            <!-- TODO: 显示页码 -->
        </div>
    </div>



    <div slot="aside-header">
        <div class="p-4">
            <h3 class="text-white text-xl font-bold mb-4">分类筛选</h3>
            <div class="flex flex-col space-y-2">
                <button class="category-btn active px-4 py-2 bg-ark-blue text-white rounded-md" data-category="all">全部</button>
                <button class="category-btn px-4 py-2 bg-[#5a5a5a] text-white rounded-md" data-category="微故事">微故事</button>
                <button class="category-btn px-4 py-2 bg-[#5a5a5a] text-white rounded-md" data-category="事件">事件</button>
                <button class="category-btn px-4 py-2 bg-[#5a5a5a] text-white rounded-md" data-category="世界观">世界观</button>
            </div>
        </div>
    </div>

    <GoBackTool slot="tool-panel" client:load/>
</InfoLayout>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
        const container = document.getElementById('blog-container');
        const wrapper = document.getElementById('blog-scroll-wrapper');
        
        if (container && wrapper) {
            // 复制整个内容包装器以实现循环滚动
            const wrapperClone = wrapper.cloneNode(true);
            wrapperClone.id = 'blog-scroll-wrapper-clone';
            wrapper.parentNode.insertBefore(wrapperClone, wrapper.nextSibling);
            
            let isScrolling = true;
            const scrollSpeed = 0.8; // 滚动速度，值越小越慢
            
            // 当用户交互时暂停滚动
            container.addEventListener('mouseenter', function() {
                isScrolling = false;
            });
            
            container.addEventListener('mouseleave', function() {
                isScrolling = true;
            });
            
            container.addEventListener('touchstart', function() {
                isScrolling = false;
            });
            
            container.addEventListener('touchend', function() {
                isScrolling = true;
            });
            
            // 自动滚动函数
            function autoScroll() {
                if (isScrolling) {
                    container.scrollTop += scrollSpeed;
                    
                    // 当滚动到原始内容的末尾时，无缝重置到复制内容的开头
                    const wrapperHeight = wrapper.offsetHeight;
                    if (container.scrollTop >= wrapperHeight) {
                        container.scrollTop = 0;
                    }
                }
                requestAnimationFrame(autoScroll);
            }
            
            // 开始自动滚动
            autoScroll();
        }
        
        // 筛选功能
        const categoryBtns = document.querySelectorAll('.category-btn');
        const blogItems = document.querySelectorAll('.blog-item');
        
        // 从 URL 获取筛选参数
        function getSelectedCategoryFromUrl() {
            const urlParams = new URLSearchParams(window.location.search);
            return urlParams.get('category') || 'all';
        }
        
        // 更新 URL 中的筛选参数
        function updateUrl(selectedCategory) {
            const url = new URL(window.location.href);
            if (selectedCategory === 'all') {
                url.searchParams.delete('category');
            } else {
                url.searchParams.set('category', selectedCategory);
            }
            window.history.pushState({}, '', url);
        }
        
        // 执行筛选操作
        function performFilter(selectedCategory) {
            // 移除所有按钮的 active 类
            categoryBtns.forEach(b => {
                b.classList.remove('active', 'bg-ark-blue');
                b.classList.add('bg-[#5a5a5a]');
            });
            
            // 添加当前按钮的 active 类
            const activeBtn = document.querySelector(`.category-btn[data-category="${selectedCategory}"]`);
            if (activeBtn) {
                activeBtn.classList.add('active', 'bg-ark-blue');
                activeBtn.classList.remove('bg-[#5a5a5a]');
            }
            
            // 筛选文章
            blogItems.forEach(item => {
                if (selectedCategory === 'all' || item.dataset.category === selectedCategory) {
                    item.style.display = 'flex';
                } else {
                    item.style.display = 'none';
                }
            });
            
            // 重置滚动位置
            const blogContainer = document.getElementById('blog-container');
            if (blogContainer) {
                blogContainer.scrollTop = 0;
            }
        }
        
        // 初始化页面时，根据 URL 参数执行筛选
        const initialCategory = getSelectedCategoryFromUrl();
        performFilter(initialCategory);
        
        // 为筛选按钮添加点击事件
        categoryBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const selectedCategory = this.dataset.category;
                updateUrl(selectedCategory);
                performFilter(selectedCategory);
            });
        });
    });
</script>
