---
import {getCollection} from 'astro:content'
// import {Debug} from 'astro:components'
import InfoLayout from "../../layouts/InfoLayout.astro"
import InfoCard from "../../components/InfoCard.astro"
import GoBackTool from "../../components/GoBackTool"

const base = import.meta.env.BASE_URL
const allBlog = await getCollection("blog");

// 辅助函数：获取缩略图路径
function getThumbnailPath(category: string | undefined, thumbnail: string | undefined): string {
    const categoryToThumbnail: Record<string, string> = {
        "微故事": "ACTIVITY.jpg",
        "事件": "NEWS.jpg",
        "世界观": "ANNOUNCEMENT.jpg"
    };
    return thumbnail ?? categoryToThumbnail[category as keyof typeof categoryToThumbnail] ?? "ACTIVITY.jpg";
}
---

<InfoLayout title="BLOG" subTitle="博客" tabTitle="博客">
    <div id="blog-container" class="h-full flex-auto mr-[-16px] overflow-x-hidden overflow-y-scroll">
        <div id="blog-scroll-wrapper">
            <nav id="blog-content" class="max-w-[80.75rem] mx-auto">
                {
                    (allBlog.length > 0) && allBlog.map((item, index) =>
                                <div class="w-full mb-16">
                                    <a target="_blank" href={`${base}blog/${item.slug}`} title={item.data.title ?? item.id} class="w-full block relative">
                                        <img class="w-full h-[400px] object-cover object-center" 
                                             src={`${base}info-thumbnail/${getThumbnailPath(item.data.category, item.data.thumbnail)}`} 
                                             alt="Thumbnail"/>
                                        <div class="absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black/80 to-transparent">
                                            <div class="text-ark-blue text-2xl font-bold mb-2">{item.data.category ?? "未分类"}</div>
                                            <div class="text-white text-4xl font-bold mb-2">{item.data.title ?? item.id}</div>
                                            <div class="text-white/80 text-lg">{item.id.substring(0, 4)} // {item.id.substring(5, 7)} / {item.id.substring(8, 10)}</div>
                                        </div>
                                    </a>
                                </div>
                            )
                }
                <!--<Debug {allBlog}/>-->
            </nav>
            <div class="text-center text-2xl font-n15eBold pt-12 pb-16">- END -</div>
            <!-- TODO: 显示页码 -->
        </div>
    </div>

    <div slot="aside-footer">
        <!-- TODO: 分组类型选择 -->
    </div>

    <GoBackTool slot="tool-panel" client:load/>
</InfoLayout>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
        const container = document.getElementById('blog-container');
        const wrapper = document.getElementById('blog-scroll-wrapper');
        
        if (container && wrapper) {
            // 复制整个内容包装器以实现循环滚动
            const wrapperClone = wrapper.cloneNode(true);
            wrapperClone.id = 'blog-scroll-wrapper-clone';
            wrapper.parentNode.insertBefore(wrapperClone, wrapper.nextSibling);
            
            let isScrolling = true;
            const scrollSpeed = 0.8; // 滚动速度，值越小越慢
            
            // 当用户交互时暂停滚动
            container.addEventListener('mouseenter', function() {
                isScrolling = false;
            });
            
            container.addEventListener('mouseleave', function() {
                isScrolling = true;
            });
            
            container.addEventListener('touchstart', function() {
                isScrolling = false;
            });
            
            container.addEventListener('touchend', function() {
                isScrolling = true;
            });
            
            // 自动滚动函数
            function autoScroll() {
                if (isScrolling) {
                    container.scrollTop += scrollSpeed;
                    
                    // 当滚动到原始内容的末尾时，无缝重置到复制内容的开头
                    const wrapperHeight = wrapper.offsetHeight;
                    if (container.scrollTop >= wrapperHeight) {
                        container.scrollTop = 0;
                    }
                }
                requestAnimationFrame(autoScroll);
            }
            
            // 开始自动滚动
            autoScroll();
        }
    });
</script>
